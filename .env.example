# Telegram bot token from @BotFather
BOT_TOKEN=

# OpenAI API key (for Whisper + GPT-4o-mini)
OPENAI_API_KEY=

# SQLite database file. Parent dirs are created on first run.
# Local dev default: ./data/bot.db
# On VPS, use an absolute path, e.g. /var/lib/smart-butts-bot/bot.db
DATABASE_PATH=./data/bot.db

# Optional: pre-configured chat IDs; otherwise discovered via /start
# HUSBAND_CHAT_ID=
# WIFE_CHAT_ID=

# Optional: override default sheet_user labels (stored in tasks.user)
# HUSBAND_SHEET_USER=alexey
# WIFE_SHEET_USER=tanyu

# One-time data import only — needed by scripts/import-from-sheets.ts
# Not required by the running bot.
# GOOGLE_SHEET_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# TASKS_SHEET_NAME=Sheet1
# USERS_SHEET_NAME=Users
# USERS_SHEET_INDEX=
